<!-- Add this inside your AndroidManifest.xml <application> tag -->

<!-- Set OnboardingActivity as the LAUNCHER (first screen) -->
<activity
    android:name=".OnboardingActivity"
    android:theme="@style/Theme.HealthHubCM.Onboarding"
    android:exported="true"
    android:screenOrientation="portrait">
    <intent-filter>
        <action android:name="android.intent.action.MAIN"/>
        <category android:name="android.intent.category.LAUNCHER"/>
    </intent-filter>
</activity>

<!-- Buyer home (no launcher intent filter — navigated to from OnboardingActivity) -->
<activity
    android:name=".BuyerHomeActivity"
    android:theme="@style/Theme.HealthHubCM"
    android:screenOrientation="portrait"/>

<!-- Seller registration -->
<activity
    android:name=".SellerRegisterActivity"
    android:theme="@style/Theme.HealthHubCM"
    android:screenOrientation="portrait"/>
